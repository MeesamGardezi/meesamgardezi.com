<!-- ══════════════════ CUSTOM CURSOR ══════════════════ -->
<div class="cursor-label" id="cursorLabel">
    <!-- Default: mouse -->
    <svg class="cursor-svg cursor-default" xmlns="http://www.w3.org/2000/svg" width="20" height="30" viewBox="0 0 20 30" fill="none">
        <path d="M10 0.5 Q10 4 10 7" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <path d="M1.5 13 Q1.5 8 10 7 Q18.5 8 18.5 13 L18.5 22 Q18.5 28.5 10 28.5 Q1.5 28.5 1.5 22 Z"
              fill="url(#mouseGrad)" stroke="white" stroke-width="1.5"/>
        <line x1="10" y1="7" x2="10" y2="15" stroke="white" stroke-width="1" opacity="0.5"/>
        <rect x="8.25" y="10" width="3.5" height="7" rx="1.75" fill="white" opacity="0.75"/>
        <defs>
            <linearGradient id="mouseGrad" x1="1.5" y1="7" x2="18.5" y2="28.5" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#0ea5e9"/>
                <stop offset="100%" stop-color="#6366f1"/>
            </linearGradient>
        </defs>
    </svg>
    <!-- Hover: click state -->
    <svg class="cursor-svg cursor-click" xmlns="http://www.w3.org/2000/svg" width="20" height="30" viewBox="0 0 20 30" fill="none">
        <path d="M10 0.5 Q10 4 10 7" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <path d="M1.5 13 Q1.5 8 10 7 Q18.5 8 18.5 13 L18.5 22 Q18.5 28.5 10 28.5 Q1.5 28.5 1.5 22 Z"
              fill="url(#mouseGrad2)" stroke="white" stroke-width="1.5"/>
        <path d="M1.5 13 Q1.5 8 10 7 L10 15 L1.5 15 Z" fill="white" opacity="0.25"/>
        <line x1="10" y1="7" x2="10" y2="15" stroke="white" stroke-width="1" opacity="0.5"/>
        <rect x="8.25" y="10" width="3.5" height="7" rx="1.75" fill="white" opacity="0.75"/>
        <line x1="10" y1="3" x2="10" y2="0.5" stroke="#38bdf8" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="4.5" x2="16" y2="2.5" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="6" y1="4.5" x2="4" y2="2.5" stroke="#38bdf8" stroke-width="1.5" stroke-linecap="round"/>
        <defs>
            <linearGradient id="mouseGrad2" x1="1.5" y1="7" x2="18.5" y2="28.5" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#38bdf8"/>
                <stop offset="100%" stop-color="#818cf8"/>
            </linearGradient>
        </defs>
    </svg>
</div>

