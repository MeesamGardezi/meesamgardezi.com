  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title><%= title %></title>
  <meta name="description" content="<%= description %>" />
  <meta name="author" content="Meesam Gardezi" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="<%= canonical %>" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:url" content="<%= canonical %>" />
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : siteUrl + '/images/og-home.png' %>" />
  <meta property="og:site_name" content="Meesam Gardezi" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= title %>" />
  <meta name="twitter:description" content="<%= description %>" />
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : siteUrl + '/images/og-home.png' %>" />
  <meta name="twitter:creator" content="@meesamgardezi" />

  <!-- Structured Data: Person -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Meesam Gardezi",
    "url": "<%= siteUrl %>",
    "sameAs": [
      "https://github.com/MeesamGardezi",
      "https://linkedin.com/in/meesamgardezi"
    ],
    "jobTitle": "Full-Stack Developer & AI Builder",
    "description": "Full-stack developer specialising in Flutter, Firebase, Node.js, and AI/LLM applications.",
    "email": "muhammadmeesamgardezi@gmail.com",
    "knowsAbout": ["Flutter", "Firebase", "Node.js", "AI/LLM", "SaaS", "Mobile Development"]
  }
  </script>

  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
  <script type="application/ld+json"><%- structuredData %></script>
  <% } %>

  <!-- Favicon -->
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css" />

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
