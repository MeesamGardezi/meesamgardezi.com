<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof post !== 'undefined' && post ? 'Edit Post' : 'New Post' %> | Admin | Meesam Gardezi</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
    <%- include('../partials/admin-nav', { activeNav: 'posts' }) %>

    <main class="admin-main">
        <header class="admin-header">
            <div>
                <h1><%= typeof post !== 'undefined' && post ? 'Edit Post' : 'New Post' %></h1>
                <p><a href="/admin/posts">&larr; Back to Posts</a></p>
            </div>
        </header>

        <form id="postForm" class="post-editor">
            <div class="editor-main">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" required placeholder="Post title..."
                        value="<%= typeof post !== 'undefined' && post ? post.title : '' %>">
                </div>

                <div class="form-group">
                    <label for="slug">Slug</label>
                    <input type="text" id="slug" name="slug" required placeholder="post-url-slug"
                        value="<%= typeof post !== 'undefined' && post ? post.slug : '' %>">
                    <small>URL-friendly identifier. Auto-generated from title if left empty.</small>
                </div>

                <div class="form-group">
                    <label for="excerpt">Excerpt</label>
                    <textarea id="excerpt" name="excerpt" rows="3" placeholder="Brief description of the post..."><%= typeof post !== 'undefined' && post ? post.excerpt : '' %></textarea>
                </div>

                <div class="form-group">
                    <label for="contentType">Content Type</label>
                    <div class="content-type-toggle">
                        <label class="radio-label">
                            <input type="radio" name="contentType" id="contentTypeMarkdown" value="markdown"
                                <%= (typeof post === 'undefined' || !post || (post.contentType || 'markdown') === 'markdown') ? 'checked' : '' %>>
                            Markdown
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="contentType" id="contentTypeHtml" value="html"
                                <%= (typeof post !== 'undefined' && post && post.contentType === 'html') ? 'checked' : '' %>>
                            HTML
                        </label>
                    </div>
                    <small>HTML mode lets you write rich content with images, quotes, and custom formatting.</small>
                </div>

                <div class="form-group">
                    <label for="content">Content <small id="contentTypeLabel">(Markdown supported)</small></label>
                    <textarea id="content" name="content" rows="24" placeholder="Write your post content..."><%= typeof post !== 'undefined' && post ? post.content : '' %></textarea>
                </div>
            </div>

            <div class="editor-sidebar">
                <div class="editor-panel">
                    <h3>Publish</h3>
                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" id="published" name="published"
                                <%= typeof post !== 'undefined' && post && post.published ? 'checked' : '' %>>
                            Published
                        </label>
                    </div>
                    <div class="editor-actions">
                        <button type="submit" class="btn-admin-primary" id="saveBtn">
                            <span><%= typeof post !== 'undefined' && post ? 'Update Post' : 'Create Post' %></span>
                        </button>
                    </div>
                </div>

                <div class="editor-panel">
                    <h3>Cover Image</h3>
                    <div class="form-group">
                        <input type="url" id="coverImage" name="coverImage" placeholder="https://example.com/image.jpg"
                            value="<%= typeof post !== 'undefined' && post && post.coverImage ? post.coverImage : '' %>">
                        <small>Direct URL to cover image</small>
                    </div>
                </div>

                <div class="editor-panel">
                    <h3>Tags</h3>
                    <div class="form-group">
                        <input type="text" id="tags" name="tags" placeholder="flutter, firebase, saas"
                            value="<%= typeof post !== 'undefined' && post && post.tags ? post.tags.join(', ') : '' %>">
                        <small>Comma-separated tags</small>
                    </div>
                </div>
            </div>
        </form>
    </main>

    <div id="editorData"
        data-is-edit="<%= typeof post !== 'undefined' && post ? 'true' : 'false' %>"
        data-post-id="<%= typeof post !== 'undefined' && post ? post.id : '' %>"
    ></div>

    <script>
        // Read server data from data attributes (avoids EJS-in-script parse issues)
        const editorData = document.getElementById('editorData').dataset;
        const isEdit = editorData.isEdit === 'true';
        const postId = editorData.postId;

        // Content type toggle
        const contentTypeLabel = document.getElementById('contentTypeLabel');
        const contentTextarea = document.getElementById('content');
        document.querySelectorAll('input[name="contentType"]').forEach(radio => {
            radio.addEventListener('change', () => {
                if (radio.value === 'html') {
                    contentTypeLabel.textContent = '(HTML — use <h2>, <p>, <blockquote>, <img>, etc.)';
                    contentTextarea.placeholder = 'Write your post in HTML...\n\n<h2>My Heading</h2>\n<p>My paragraph...</p>\n<blockquote>A key insight.</blockquote>';
                } else {
                    contentTypeLabel.textContent = '(Markdown supported)';
                    contentTextarea.placeholder = 'Write your post in Markdown...';
                }
            });
        });

        // Set initial label state
        const initialType = document.querySelector('input[name="contentType"]:checked')?.value || 'markdown';
        if (initialType === 'html') {
            contentTypeLabel.textContent = '(HTML — use <h2>, <p>, <blockquote>, <img>, etc.)';
        }

        // Auto-generate slug from title
        const titleInput = document.getElementById('title');
        const slugInput = document.getElementById('slug');
        let slugManuallyEdited = isEdit;

        titleInput.addEventListener('input', () => {
            if (!slugManuallyEdited) {
                slugInput.value = titleInput.value
                    .toLowerCase()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-')
                    .trim();
            }
        });

        slugInput.addEventListener('input', () => {
            slugManuallyEdited = true;
        });

        // Form submission
        document.getElementById('postForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('saveBtn');
            btn.disabled = true;
            btn.innerHTML = '<span>Saving...</span>';

            const data = {
                title: document.getElementById('title').value,
                slug: document.getElementById('slug').value,
                excerpt: document.getElementById('excerpt').value,
                content: document.getElementById('content').value,
                contentType: document.querySelector('input[name="contentType"]:checked')?.value || 'markdown',
                coverImage: document.getElementById('coverImage').value,
                published: document.getElementById('published').checked,
                tags: document.getElementById('tags').value.split(',').map(t => t.trim()).filter(Boolean),
            };

            const url = isEdit ? `/admin/posts/${postId}` : '/admin/posts';
            const method = isEdit ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                if (res.ok) {
                    const result = await res.json();
                    window.location.href = '/admin/posts';
                } else {
                    const err = await res.json();
                    alert(err.error || 'Failed to save post');
                }
            } catch (err) {
                alert('Error saving post');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span>' + (isEdit ? 'Update Post' : 'Create Post') + '</span>';
            }
        });
    </script>
</body>
</html>
